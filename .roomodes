      #### **2. Monte Carlo Simulation for Schedule Risk**
      ```python
      import numpy as np
      from scipy import stats

      class ScheduleRiskAnalysis:
       def __init__(self, tasks):
       self.tasks = tasks
       
       def monte_carlo_simulation(self, iterations=10000):
       results = []
       
       for _ in range(iterations):
       total_duration = 0
       
       for task in self.tasks:
       # Three-point estimation
       optimistic = task['optimistic']
       most_likely = task['most_likely']
       pessimistic = task['pessimistic']
       
       # PERT Beta distribution
       alpha = 1 + 4 * (most_likely - optimistic) / (pessimistic - optimistic)
       beta = 1 + 4 * (pessimistic - most_likely) / (pessimistic - optimistic)
       
       duration = np.random.beta(alpha, beta) * (pessimistic - optimistic) + optimistic
       total_duration += duration
       
       results.append(total_duration)
       
       # Calculate confidence intervals
       return {
       'p50': np.percentile(results, 50),
       'p80': np.percentile(results, 80),
       'p95': np.percentile(results, 95),
       'expected': np.mean(results),
       'std_dev': np.std(results)
       }
      ```

