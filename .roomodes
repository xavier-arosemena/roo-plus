      ## 🛠️ PROJECT MANAGEMENT TOOLS INTEGRATION

      ### **1. JIRA Automation Scripts**
      ```python
      from jira import JIRA
      import pandas as pd

      class JIRAAutomation:
       def __init__(self, server, username, api_token):
       self.jira = JIRA(server=server, basic_auth=(username, api_token))
       
       def bulk_create_stories(self, epic_key, stories_csv):
       df = pd.read_csv(stories_csv)
       created_issues = []
       
       for _, row in df.iterrows():
       issue_dict = {
       'project': {'key': row['project_key']},
       'summary': row['summary'],
       'description': row['description'],
       'issuetype': {'name': 'Story'},
       'parent': {'key': epic_key},
       'customfield_10002': row['story_points'], # Story points field
       'components': [{'name': row['component']}],
       'labels': row['labels'].split(',')
       }
       
       issue = self.jira.create_issue(fields=issue_dict)
       created_issues.append(issue.key)
       
       # Create subtasks if specified
       if pd.notna(row['subtasks']):
       self.create_subtasks(issue.key, row['subtasks'])
       
       return created_issues
       
       def generate_sprint_report(self, sprint_id):
       sprint = self.jira.sprint(sprint_id)
       issues = self.jira.search_issues(f'sprint = {sprint_id}')
       
       report = {
       'sprint_name': sprint.name,
       'total_points': sum(issue.fields.customfield_10002 or 0 for issue in issues),
       'completed_points': sum(
       issue.fields.customfield_10002 or 0 
       for issue in issues 
       if issue.fields.status.name == 'Done'
       ),
       'by_status': self.group_by_status(issues),
       'by_assignee': self.group_by_assignee(issues),
       'blockers': [i for i in issues if 'blocker' in i.fields.labels]
       }
       
       return report
      ```

      ### **2. Microsoft Project Integration**
      ```vba
      ' MS Project VBA Automation
      Sub OptimizeProjectSchedule()
       Dim proj As Project
       Set proj = ActiveProject
       
       ' Level resources automatically
       LevelingOptions LevelEntireProject:=True, _
       LevelingOrder:=pjLevelPriority, _
       LevelWithinSlack:=True
       
       ' Identify critical path
       ViewApply Name:="Gantt Chart"
       FilterApply Name:="Critical"
       
       ' Calculate schedule compression opportunities
       Dim criticalTasks As Tasks
       Set criticalTasks = ActiveSelection.Tasks
       
       Dim compressionOpportunities As Collection
       Set compressionOpportunities = New Collection
       
       Dim t As Task
       For Each t In criticalTasks
       If t.Duration > 40 Then ' Tasks longer than 1 week
       compressionOpportunities.Add t.Name & " - Consider crashing or fast-tracking"
       End If
       Next t
       
       ' Generate optimization report
       GenerateOptimizationReport compressionOpportunities
      End Sub
      ```

      ## 📊 ADVANCED PROJECT ANALYTICS

      ### **Earned Value Management (EVM)**
      ```python
      class EarnedValueAnalysis:
       def __init__(self, project_data):
       self.data = project_data
       self.bac = project_data['budget_at_completion']
       self.pac = project_data['planned_duration']
       
       def calculate_metrics(self, reporting_date):
       # Basic EVM metrics
       pv = self.planned_value(reporting_date)
       ev = self.earned_value(reporting_date)
       ac = self.actual_cost(reporting_date)
       
       # Variance metrics
       cv = ev - ac # Cost Variance
       sv = ev - pv # Schedule Variance
       
       # Performance indices
       cpi = ev / ac if ac > 0 else 0 # Cost Performance Index
       spi = ev / pv if pv > 0 else 0 # Schedule Performance Index
       
       # Forecasting
       eac = self.bac / cpi if cpi > 0 else self.bac # Estimate at Completion
       etc = eac - ac # Estimate to Complete
       vac = self.bac - eac # Variance at Completion
       
       # Time forecasting
       eac_time = self.pac / spi if spi > 0 else self.pac
       
       return {
       'cost_variance': cv,
       'schedule_variance': sv,
       'cpi': cpi,
       'spi': spi,
       'estimate_at_completion': eac,
       'estimate_to_complete': etc,
       'variance_at_completion': vac,
       'estimated_completion_time': eac_time,
       'health_indicator': self.get_health_indicator(cpi, spi)
       }
       
       def get_health_indicator(self, cpi, spi):
       if cpi >= 0.95 and spi >= 0.95:
       return '🟢 On Track'
       elif cpi >= 0.85 and spi >= 0.85:
       return '🟡 Minor Issues'
       else:
       return '🔴 Major Issues'
      ```

