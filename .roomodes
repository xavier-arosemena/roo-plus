      ### **Performance Optimization Patterns (10-100x Speedup)**

      #### **1. Algorithmic Optimizations**
      ```python
      import functools
      import bisect
      from collections import defaultdict, deque
      from typing import List, Dict, Optional, Tuple
      import numpy as np
      from numba import jit, vectorize

      # ❌ AVOID: Inefficient algorithms
      def find_duplicates_slow(data: List[int]) -> List[int]:
       duplicates = []
       for i, item in enumerate(data):
       for j, other in enumerate(data[i+1:], i+1):
       if item == other and item not in duplicates:
       duplicates.append(item)
       return duplicates # O(n³) complexity

      # ✅ IMPLEMENT: Optimized algorithm
      def find_duplicates_optimized(data: List[int]) -> List[int]:
       seen = set()
       duplicates = set()
       for item in data:
       if item in seen:
       duplicates.add(item)
       else:
       seen.add(item)
       return list(duplicates) # O(n) complexity

      # Advanced optimization with NumPy
      def find_duplicates_numpy(data: np.ndarray) -> np.ndarray:
       unique, counts = np.unique(data, return_counts=True)
       return unique[counts > 1] # Vectorized, much faster

      # JIT compilation for numerical operations
      @jit(nopython=True) # Compile to machine code
      def compute_distances_jit(points: np.ndarray) -> np.ndarray:
       n = points.shape[0]
       distances = np.zeros((n, n))
       
       for i in range(n):
       for j in range(i + 1, n):
       dist = np.sqrt(np.sum((points[i] - points[j]) ** 2))
       distances[i, j] = dist
       distances[j, i] = dist
       
       return distances

      # Vectorized operations with NumPy
      def compute_distances_vectorized(points: np.ndarray) -> np.ndarray:
       # Broadcasting for vectorized computation
       diff = points[:, np.newaxis] - points[np.newaxis,:]
       return np.sqrt(np.sum(diff ** 2, axis=2))

      # Memory-efficient processing for large datasets
      class ChunkedProcessor:
       def __init__(self, chunk_size: int = 10000):
       self.chunk_size = chunk_size
       
       def process_large_dataset(self, data_iterator, process_func):
       """Process data in chunks to avoid memory issues"""
       results = []
       chunk = []
       
       for item in data_iterator:
       chunk.append(item)
       
       if len(chunk) >= self.chunk_size:
       # Process chunk
       chunk_result = process_func(chunk)
       results.extend(chunk_result)
       chunk.clear() # Clear to free memory
       
       # Process remaining items
       if chunk:
       chunk_result = process_func(chunk)
       results.extend(chunk_result)
       
       return results

      # Efficient caching strategies
      class LRUCache:
       def __init__(self, capacity: int):
       self.capacity = capacity
       self.cache: Dict = {}
       self.order = deque()
       
       def get(self, key) -> Optional[any]:
       if key in self.cache:
       # Move to end (most recently used)
       self.order.remove(key)
       self.order.append(key)
       return self.cache[key]
       return None
       
       def put(self, key, value) -> None:
       if key in self.cache:
       # Update existing
       self.order.remove(key)
       elif len(self.cache) >= self.capacity:
       # Remove least recently used
       oldest = self.order.popleft()
       del self.cache[oldest]
       
       self.cache[key] = value
       self.order.append(key)

      # Using built-in functools.lru_cache for function memoization
      @functools.lru_cache(maxsize=1000)
      def fibonacci_cached(n: int) -> int:
       if n < 2:
       return n
       return fibonacci_cached(n-1) + fibonacci_cached(n-2)

      # Advanced data structure optimization
      class OptimizedCounter:
       """Memory-efficient counter using __slots__"""
       __slots__ = ('_data', '_total')
       
       def __init__(self):
       self._data: Dict[str, int] = defaultdict(int)
       self._total: int = 0
       
       def increment(self, key: str, count: int = 1) -> None:
       self._data[key] += count
       self._total += count
       
       def most_common(self, n: int) -> List[Tuple[str, int]]:
       return sorted(self._data.items(), key=lambda x: x[1], reverse=True)[:n]
       
       @property
       def total(self) -> int:
       return self._total
      ```

      #### **2. Async Programming Optimization**
      ```python
      import asyncio
      import aiohttp
      import aiofiles
      import aiodns
      from concurrent.futures import ThreadPoolExecutor, ProcessPoolExecutor
      from typing import AsyncIterator, AsyncGenerator
      import time

      # ❌ AVOID: Synchronous I/O in async context
      async def fetch_data_slow(urls: List[str]) -> List[str]:
       results = []
       for url in urls:
       # This blocks the event loop!
       response = requests.get(url)
       results.append(response.text)
       return results

      # ✅ IMPLEMENT: Proper async I/O
      class AsyncHTTPClient:
       def __init__(self, max_connections: int = 100, timeout: int = 30):
       self.timeout = aiohttp.ClientTimeout(total=timeout)
       self.connector = aiohttp.TCPConnector(
       limit=max_connections,
       limit_per_host=20,
       enable_cleanup_closed=True,
       use_dns_cache=True,
       keepalive_timeout=300
       )
       self.session = None
       
       async def __aenter__(self):
       self.session = aiohttp.ClientSession(
       connector=self.connector,
       timeout=self.timeout
       )
       return self
       
       async def __aexit__(self, exc_type, exc_val, exc_tb):
       if self.session:
       await self.session.close()
       
       async def fetch_single(self, url: str) -> Optional[str]:
       try:
       async with self.session.get(url) as response:
       if response.status == 200:
       return await response.text()
       return None
       except asyncio.TimeoutError:
       print(f"Timeout fetching {url}")
       return None
       except Exception as e:
       print(f"Error fetching {url}: {e}")
       return None
       
       async def fetch_batch(self, urls: List[str], 
       max_concurrent: int = 50) -> List[Optional[str]]:
       semaphore = asyncio.Semaphore(max_concurrent)
       
       async def fetch_with_semaphore(url: str) -> Optional[str]:
       async with semaphore:
       return await self.fetch_single(url)
       
       tasks = [fetch_with_semaphore(url) for url in urls]
       return await asyncio.gather(*tasks, return_exceptions=False)

      # Advanced async patterns
      class AsyncDataProcessor:
       def __init__(self, max_workers: int = None):
       self.thread_pool = ThreadPoolExecutor(max_workers=max_workers)
       self.process_pool = ProcessPoolExecutor(max_workers=max_workers)
       
       async def process_with_backpressure(self, 
       data_stream: AsyncIterator,
       buffer_size: int = 1000) -> AsyncGenerator:
       """Process stream with backpressure control"""
       buffer = []
       
       async for item in data_stream:
       buffer.append(item)
       
       if len(buffer) >= buffer_size:
       # Process buffer in thread pool for CPU-intensive work
       processed = await asyncio.get_event_loop().run_in_executor(
       self.thread_pool,
       self._process_batch,
       buffer.copy()
       )
       
       for result in processed:
       yield result
       
       buffer.clear()
       
       # Process remaining items
       if buffer:
       processed = await asyncio.get_event_loop().run_in_executor(
       self.thread_pool,
       self._process_batch,
       buffer
       )
       
       for result in processed:
       yield result
       
       def _process_batch(self, batch: List) -> List:
       """CPU-intensive processing in separate thread"""
       return [self._process_item(item) for item in batch]
       
       def _process_item(self, item) -> any:
       # Simulate CPU-intensive work
       time.sleep(0.01) # Replace with actual processing
       return f"processed_{item}"
       
       async def parallel_file_processing(self, file_paths: List[str]) -> List[str]:
       """Process multiple files concurrently"""
       async def process_file(path: str) -> str:
       async with aiofiles.open(path, 'r') as f:
       content = await f.read()
       # Process content in thread pool if CPU-intensive
       return await asyncio.get_event_loop().run_in_executor(
       self.thread_pool,
       self._process_file_content,
       content
       )
       
       tasks = [process_file(path) for path in file_paths]
       return await asyncio.gather(*tasks)
       
       def _process_file_content(self, content: str) -> str:
       # CPU-intensive file processing
       return content.upper() # Example processing
       
       async def cleanup(self):
       self.thread_pool.shutdown(wait=True)
       self.process_pool.shutdown(wait=True)

      # Async context manager for resource management
      class AsyncDatabasePool:
       def __init__(self, connection_string: str, pool_size: int = 10):
       self.connection_string = connection_string
       self.pool_size = pool_size
       self.pool = None
       
       async def __aenter__(self):
       import asyncpg # PostgreSQL async driver
       self.pool = await asyncpg.create_pool(
       self.connection_string,
       min_size=1,
       max_size=self.pool_size,
       command_timeout=60,
       server_settings={
       'jit': 'off' # Disable JIT for better connection performance
       }
       )
       return self
       
       async def __aexit__(self, exc_type, exc_val, exc_tb):
       if self.pool:
       await self.pool.close()
       
       async def execute_query(self, query: str, *args) -> List[dict]:
       async with self.pool.acquire() as connection:
       rows = await connection.fetch(query, *args)
       return [dict(row) for row in rows]
       
       async def execute_batch(self, queries: List[Tuple[str, tuple]]) -> List[List[dict]]:
       """Execute multiple queries concurrently"""
       async def execute_single(query: str, args: tuple) -> List[dict]:
       return await self.execute_query(query, *args)
       
       tasks = [execute_single(query, args) for query, args in queries]
       return await asyncio.gather(*tasks)
      ```

      ### **FastAPI Optimization Patterns**

      #### **1. High-Performance API Implementation**
      ```python
      from fastapi import FastAPI, HTTPException, Depends, BackgroundTasks
      from fastapi.middleware.cors import CORSMiddleware
      from fastapi.middleware.gzip import GZipMiddleware
      from fastapi.responses import StreamingResponse
      from pydantic import BaseModel, Field, validator
      from typing import Optional, List, AsyncIterator
      import orjson
      import redis.asyncio as redis
      from sqlalchemy.ext.asyncio import AsyncSession, create_async_engine
      from sqlalchemy.orm import sessionmaker
      import logging

      # Custom JSON response using orjson (faster than default)
      class ORJSONResponse(JSONResponse):
       media_type = "application/json"
       
       def render(self, content) -> bytes:
       return orjson.dumps(content)

      # Optimized FastAPI app configuration
      app = FastAPI(
       title="API",
       version="1.0.0",
       default_response_class=ORJSONResponse, # Use faster JSON serialization
       docs_url="/docs" if DEBUG else None, # Disable docs in production
       redoc_url="/redoc" if DEBUG else None
      )

      # Middleware stack optimization
      app.add_middleware(GZipMiddleware, minimum_size=1000)
      app.add_middleware(
       CORSMiddleware,
       allow_origins=["*"] if DEBUG else ALLOWED_ORIGINS,
       allow_credentials=True,
       allow_methods=["*"],
       allow_headers=["*"],
      )

      # Connection pools
      engine = create_async_engine(
       DATABASE_URL,
       pool_size=20,
       max_overflow=30,
       pool_pre_ping=True,
       pool_recycle=3600,
       echo=DEBUG
      )
      AsyncSessionLocal = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

      redis_client = redis.Redis.from_url(REDIS_URL, decode_responses=True, max_connections=20)

      # Optimized models with validation
      class UserCreate(BaseModel):
       email: str = Field(..., regex=r'^[^@]+@[^@]+\.[^@]+$')
       name: str = Field(..., min_length=1, max_length=100)
       age: Optional[int] = Field(None, ge=0, le=150)
       
       @validator('email')
       def email_must_be_lowercase(cls, v):
       return v.lower()
       
       class Config:
       # Use orjson for faster serialization
       json_loads = orjson.loads
       json_dumps = lambda v, *, default: orjson.dumps(v, default=default).decode()

      # Dependency injection with caching
      async def get_db() -> AsyncIterator[AsyncSession]:
       async with AsyncSessionLocal() as session:
       try:
       yield session
       await session.commit()
       except Exception:
       await session.rollback()
       raise
       finally:
       await session.close()

      async def get_redis() -> redis.Redis:
       return redis_client

      # Cached dependency
      @lru_cache(maxsize=1000)
      def get_user_permissions(user_id: int) -> List[str]:
       # This would typically be a database call
       return ["read", "write"]

      # High-performance endpoints
      @app.get("/users/{user_id}", response_model=UserResponse)
      async def get_user(
       user_id: int,
       db: AsyncSession = Depends(get_db),
       redis: redis.Redis = Depends(get_redis)
      ):
       # Check cache first
       cache_key = f"user:{user_id}"
       cached_user = await redis.get(cache_key)
       
       if cached_user:
       return orjson.loads(cached_user)
       
       # Database query with optimized loading
       result = await db.execute(
       select(User).options(
       selectinload(User.profiles), # Eager load relationships
       selectinload(User.preferences)
       ).where(User.id == user_id)
       )
       user = result.scalar_one_or_none()
       
       if not user:
       raise HTTPException(status_code=404, detail="User not found")
       
       user_data = UserResponse.from_orm(user)
       
       # Cache for 5 minutes
       await redis.setex(cache_key, 300, orjson.dumps(user_data.dict()))
       
       return user_data

      # Bulk operations endpoint
      @app.post("/users/bulk", response_model=BulkOperationResponse)
      async def create_users_bulk(
       users: List[UserCreate],
       background_tasks: BackgroundTasks,
       db: AsyncSession = Depends(get_db)
      ):
       if len(users) > 1000:
       raise HTTPException(status_code=400, detail="Too many users in batch")
       
       # Validate all users first
       validated_users = []
       for user_data in users:
       # Additional validation logic
       validated_users.append(User(**user_data.dict()))
       
       # Bulk insert
       db.add_all(validated_users)
       await db.flush() # Get IDs without committing
       
       # Background task for post-processing
       user_ids = [user.id for user in validated_users]
       background_tasks.add_task(process_new_users, user_ids)
       
       return BulkOperationResponse(
       created_count=len(validated_users),
       status="success"
       )

      # Streaming response for large datasets
      @app.get("/users/export")
      async def export_users(
       format: str = "csv",
       db: AsyncSession = Depends(get_db)
      ):
       async def generate_csv():
       yield "id,email,name,created_at\n"
       
       # Stream results to avoid memory issues
       async for user in db.stream(
       select(User).execution_options(stream_results=True)
       ):
       yield f"{user.id},{user.email},{user.name},{user.created_at}\n"
       
       return StreamingResponse(
       generate_csv(),
       media_type="text/csv",
       headers={"Content-Disposition": "attachment; filename=users.csv"}
       )

      # Background task processing
      async def process_new_users(user_ids: List[int]):
       """Background processing for new users"""
       async with AsyncSessionLocal() as db:
       for user_id in user_ids:
       # Send welcome email, create profile, etc.
       await send_welcome_email(user_id)
       await create_user_profile(user_id)

      # Health check endpoint
      @app.get("/health")
      async def health_check(db: AsyncSession = Depends(get_db)):
       try:
       # Check database connection
       await db.execute(text("SELECT 1"))
       db_status = "healthy"
       except Exception as e:
       db_status = f"unhealthy: {e}"
       
       try:
       # Check Redis connection
       await redis_client.ping()
       redis_status = "healthy"
       except Exception as e:
       redis_status = f"unhealthy: {e}"
       
       return {
       "status": "healthy" if db_status == "healthy" and redis_status == "healthy" else "unhealthy",
       "database": db_status,
       "redis": redis_status,
       "timestamp": datetime.utcnow().isoformat()
       }
      ```

      ### **Data Processing Optimization**

      #### **1. Pandas and NumPy Optimization**
      ```python
      import pandas as pd
      import numpy as np
      from numba import jit
      import dask.dataframe as dd
      from concurrent.futures import ProcessPoolExecutor
      import pyarrow as pa
      import pyarrow.parquet as pq

      # ❌ AVOID: Inefficient pandas operations
      def process_data_slow(df: pd.DataFrame) -> pd.DataFrame:
       # Iterating over rows is slow
       result = []
       for index, row in df.iterrows():
       if row['value'] > 100:
       result.append({
       'id': row['id'],
       'processed_value': row['value'] * 2
       })
       return pd.DataFrame(result)

      # ✅ IMPLEMENT: Vectorized operations
      def process_data_optimized(df: pd.DataFrame) -> pd.DataFrame:
       # Vectorized operations are much faster
       mask = df['value'] > 100
       return pd.DataFrame({
       'id': df.loc[mask, 'id'],
       'processed_value': df.loc[mask, 'value'] * 2
       })

      # Advanced data processing pipeline
      class OptimizedDataProcessor:
       def __init__(self, chunk_size: int = 10000):
       self.chunk_size = chunk_size
       
       def process_large_file(self, file_path: str, output_path: str) -> None:
       """Process large CSV files in chunks"""
       # Read in chunks to handle large files
       chunks = pd.read_csv(file_path, chunksize=self.chunk_size)
       
       first_chunk = True
       for chunk in chunks:
       processed_chunk = self._process_chunk(chunk)
       
       # Append to output file
       processed_chunk.to_csv(
       output_path,
       mode='a' if not first_chunk else 'w',
       header=first_chunk,
       index=False
       )
       first_chunk = False
       
       def _process_chunk(self, chunk: pd.DataFrame) -> pd.DataFrame:
       # Optimize data types
       chunk = self._optimize_dtypes(chunk)
       
       # Vectorized operations
       chunk['processed'] = np.where(
       chunk['value'] > chunk['value'].quantile(0.95),
       chunk['value'] * 1.5,
       chunk['value']
       )
       
       # Use categorical for string columns with few unique values
       if chunk['category'].nunique() / len(chunk) < 0.5:
       chunk['category'] = chunk['category'].astype('category')
       
       return chunk
       
       def _optimize_dtypes(self, df: pd.DataFrame) -> pd.DataFrame:
       """Optimize data types to reduce memory usage"""
       for col in df.select_dtypes(include=['int64']).columns:
       col_min = df[col].min()
       col_max = df[col].max()
       
       if col_min >= 0:
       if col_max < 255:
       df[col] = df[col].astype(np.uint8)
       elif col_max < 65535:
       df[col] = df[col].astype(np.uint16)
       elif col_max < 4294967295:
       df[col] = df[col].astype(np.uint32)
       else:
       if col_min > np.iinfo(np.int8).min and col_max < np.iinfo(np.int8).max:
       df[col] = df[col].astype(np.int8)
       elif col_min > np.iinfo(np.int16).min and col_max < np.iinfo(np.int16).max:
       df[col] = df[col].astype(np.int16)
       elif col_min > np.iinfo(np.int32).min and col_max < np.iinfo(np.int32).max:
       df[col] = df[col].astype(np.int32)
       
       return df
       
       def parallel_processing(self, data_files: List[str]) -> pd.DataFrame:
       """Process multiple files in parallel"""
       with ProcessPoolExecutor() as executor:
       futures = []
       for file_path in data_files:
       future = executor.submit(pd.read_csv, file_path)
       futures.append(future)
       
       # Combine results
       dfs = [future.result() for future in futures]
       return pd.concat(dfs, ignore_index=True)

      # Dask for larger-than-memory processing
      class DaskDataProcessor:
       def __init__(self, npartitions: int = None):
       self.npartitions = npartitions or os.cpu_count()
       
       def process_large_dataset(self, file_pattern: str) -> dd.DataFrame:
       """Process datasets larger than memory using Dask"""
       # Read multiple files as Dask DataFrame
       df = dd.read_csv(file_pattern, assume_missing=True)
       
       # Optimize partitions
       df = df.repartition(npartitions=self.npartitions)
       
       # Perform operations lazily
       df = df[df['value'] > 0] # Filter
       df['log_value'] = df['value'].apply(np.log, meta=('value', 'f8')) # Transform
       df = df.groupby('category').agg({
       'value': ['sum', 'mean', 'count'],
       'log_value': 'std'
       }) # Aggregation
       
       return df
       
       def save_optimized(self, df: dd.DataFrame, output_path: str) -> None:
       """Save with optimized format"""
       # Save as Parquet for better performance
       df.to_parquet(
       output_path,
       engine='pyarrow',
       compression='snappy',
       write_index=False
       )

      # NumPy optimization with JIT compilation
      @jit(nopython=True)
      def compute_rolling_stats(data: np.ndarray, window_size: int) -> Tuple[np.ndarray, np.ndarray]:
       """Compute rolling mean and std with Numba JIT"""
       n = len(data)
       rolling_mean = np.empty(n - window_size + 1)
       rolling_std = np.empty(n - window_size + 1)
       
       for i in range(n - window_size + 1):
       window = data[i:i + window_size]
       rolling_mean[i] = np.mean(window)
       rolling_std[i] = np.std(window)
       
       return rolling_mean, rolling_std
      ```

