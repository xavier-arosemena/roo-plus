      ### **4. Observability Stack**
      ```python
      # platform/observability/custom-metrics.py
      from prometheus_client import Counter, Histogram, Gauge, generate_latest
      from flask import Flask, Response
      import time
      import psutil
      import logging
      from opentelemetry import trace, metrics
      from opentelemetry.exporter.jaeger.thrift import JaegerExporter
      from opentelemetry.sdk.trace import TracerProvider
      from opentelemetry.sdk.trace.export import BatchSpanProcessor

      class PlatformObservability:
       def __init__(self):
       # Prometheus metrics
       self.request_count = Counter(
       'platform_requests_total',
       'Total platform requests',
       ['method', 'endpoint', 'status']
       )
       
       self.request_duration = Histogram(
       'platform_request_duration_seconds',
       'Request duration in seconds',
       ['method', 'endpoint']
       )
       
       self.active_connections = Gauge(
       'platform_active_connections',
       'Number of active connections'
       )
       
       self.resource_utilization = Gauge(
       'platform_resource_utilization',
       'Platform resource utilization',
       ['resource_type']
       )
       
       # OpenTelemetry setup
       self.setup_tracing()
       
       def setup_tracing(self):
       """Setup distributed tracing"""
       trace.set_tracer_provider(TracerProvider())
       tracer = trace.get_tracer(__name__)
       
       jaeger_exporter = JaegerExporter(
       agent_host_name="jaeger-agent",
       agent_port=6831,
       )
       
       span_processor = BatchSpanProcessor(jaeger_exporter)
       trace.get_tracer_provider().add_span_processor(span_processor)
       
       def collect_system_metrics(self):
       """Collect system-level metrics"""
       # CPU utilization
       cpu_percent = psutil.cpu_percent(interval=1)
       self.resource_utilization.labels(resource_type='cpu').set(cpu_percent)
       
       # Memory utilization
       memory = psutil.virtual_memory()
       self.resource_utilization.labels(resource_type='memory').set(memory.percent)
       
       # Disk utilization
       disk = psutil.disk_usage('/')
       self.resource_utilization.labels(resource_type='disk').set(disk.percent)
       
       # Network connections
       connections = len(psutil.net_connections())
       self.active_connections.set(connections)
       
       def create_custom_dashboard(self):
       """Create Grafana dashboard JSON"""
       dashboard = {
       "dashboard": {
       "id": None,
       "title": "Platform Observability",
       "tags": ["platform", "infrastructure"],
       "timezone": "browser",
       "panels": [
       {
       "id": 1,
       "title": "Request Rate",
       "type": "graph",
       "targets": [
       {
       "expr": "rate(platform_requests_total[5m])",
       "legendFormat": "{{method}} {{endpoint}}"
       }
       ],
       "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
       },
       {
       "id": 2,
       "title": "Response Time P95",
       "type": "graph",
       "targets": [
       {
       "expr": "histogram_quantile(0.95, rate(platform_request_duration_seconds_bucket[5m]))",
       "legendFormat": "P95 Response Time"
       }
       ],
       "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
       },
       {
       "id": 3,
       "title": "Resource Utilization",
       "type": "graph",
       "targets": [
       {
       "expr": "platform_resource_utilization",
       "legendFormat": "{{resource_type}}"
       }
       ],
       "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
       }
       ],
       "time": {
       "from": "now-1h",
       "to": "now"
       },
       "refresh": "5s"
       }
       }
       
       return dashboard
      ```

