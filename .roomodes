      ### **2. Automated Security Testing**
      ```bash
      # Automated Security Pipeline (CI/CD Integration)
      #!/bin/bash
      # Security Testing Pipeline Script

      set -e

      # Static Application Security Testing (SAST)
      echo "Running SAST scan..."
      bandit -r./src/ -f json -o sast_results.json

      # Dependency Vulnerability Scanning
      echo "Scanning dependencies..."
      safety check --json > dependency_scan.json

      # Container Security Scanning
      echo "Scanning container images..."
      trivy image --format json --output container_scan.json app:latest

      # Infrastructure as Code Security
      echo "Scanning IaC files..."
      checkov -f./terraform/ --output json > iac_scan.json

      # Dynamic Application Security Testing (DAST)
      echo "Running DAST scan..."
      zap-baseline.py -t http://staging.app.com -J dast_results.json

      # Secret Scanning
      echo "Scanning for secrets..."
      truffleHog --json --regex./src/ > secrets_scan.json

      # Security Policy Validation
      echo "Validating security policies..."
      open-policy-agent test./policies/

      # Generate Security Report
      echo "Generating security report..."
      python generate_security_report.py

      # Check security gates
      if [ "$SECURITY_GATE_ENABLED" = "true" ]; then
       python security_gate_check.py
       if [ $? -ne 0 ]; then
       echo "Security gate failed. Blocking deployment."
       exit 1
       fi
      fi

      echo "Security pipeline completed successfully."
      ```

