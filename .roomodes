      #### **1. Memory Management Optimization**
      ```java
      // ❌ AVOID: Excessive object creation in loops
      public List<String> processDataSlow(List<String> data) {
       List<String> result = new ArrayList<>();
       for (String item: data) {
       result.add(new StringBuilder().append("processed_").append(item).toString());
       // Creates new StringBuilder and String objects each iteration
       }
       return result;
      }

      // ✅ IMPLEMENT: Object pooling and reuse
      public class OptimizedStringProcessor {
       private final ThreadLocal<StringBuilder> stringBuilderPool = 
       ThreadLocal.withInitial(() -> new StringBuilder(256));
       
       private final ObjectPool<List<String>> listPool = new ObjectPool<>(
       () -> new ArrayList<>(1000),
       list -> { list.clear(); return list; },
       100 // pool size
       );
       
       public List<String> processDataOptimized(List<String> data) {
       List<String> result = listPool.acquire();
       StringBuilder sb = stringBuilderPool.get();
       
       try {
       for (String item: data) {
       sb.setLength(0); // Reset without creating new object
       sb.append("processed_").append(item);
       result.add(sb.toString());
       }
       return new ArrayList<>(result); // Return defensive copy
       } finally {
       listPool.release(result);
       }
       }
      }

      // Generic Object Pool Implementation
      public class ObjectPool<T> {
       private final ConcurrentLinkedQueue<T> pool = new ConcurrentLinkedQueue<>();
       private final Supplier<T> factory;
       private final Function<T, T> reset;
       private final AtomicInteger size = new AtomicInteger(0);
       private final int maxSize;
       
       public ObjectPool(Supplier<T> factory, Function<T, T> reset, int maxSize) {
       this.factory = factory;
       this.reset = reset;
       this.maxSize = maxSize;
       
       // Pre-warm pool
       for (int i = 0; i < maxSize / 2; i++) {
       pool.offer(factory.get());
       size.incrementAndGet();
       }
       }
       
       public T acquire() {
       T obj = pool.poll();
       if (obj!= null) {
       size.decrementAndGet();
       return obj;
       }
       return factory.get();
       }
       
       public void release(T obj) {
       if (size.get() < maxSize && obj!= null) {
       pool.offer(reset.apply(obj));
       size.incrementAndGet();
       }
       }
      }
      ```

      #### **2. Parallel Stream Optimization**
      ```java
      import java.util.concurrent.*;
      import java.util.stream.Collectors;

      public class ParallelProcessingOptimizer {
       private final ForkJoinPool customThreadPool;
       
       public ParallelProcessingOptimizer(int parallelism) {
       this.customThreadPool = new ForkJoinPool(parallelism);
       }
       
       // ❌ AVOID: Using common ForkJoinPool
       public List<ProcessedData> processDataSlow(List<RawData> data) {
       return data.parallelStream() // Uses common pool, contention issues.map(this::expensiveOperation).collect(Collectors.toList());
       }
       
       // ✅ IMPLEMENT: Custom thread pool with optimal configuration
       public List<ProcessedData> processDataOptimized(List<RawData> data) {
       try {
       return customThreadPool.submit(() ->
       data.parallelStream().map(this::expensiveOperation).collect(Collectors.toCollection(
       () -> new ArrayList<>(data.size())
       ))
       ).get();
       } catch (InterruptedException | ExecutionException e) {
       Thread.currentThread().interrupt();
       throw new RuntimeException("Processing failed", e);
       }
       }
       
       // Batch processing for very large datasets
       public List<ProcessedData> processLargeDataset(List<RawData> data, int batchSize) {
       List<CompletableFuture<List<ProcessedData>>> futures = new ArrayList<>();
       
       // Split data into batches
       for (int i = 0; i < data.size(); i += batchSize) {
       int end = Math.min(i + batchSize, data.size());
       List<RawData> batch = data.subList(i, end);
       
       CompletableFuture<List<ProcessedData>> future = CompletableFuture.supplyAsync(() -> processBatch(batch), customThreadPool);
       futures.add(future);
       }
       
       // Collect all results
       return futures.stream().map(CompletableFuture::join).flatMap(List::stream).collect(Collectors.toList());
       }
       
       private List<ProcessedData> processBatch(List<RawData> batch) {
       return batch.stream().map(this::expensiveOperation).collect(Collectors.toCollection(
       () -> new ArrayList<>(batch.size())
       ));
       }
       
       private ProcessedData expensiveOperation(RawData raw) {
       // Simulate expensive operation
       try {
       Thread.sleep(1); // Replace with actual processing
       return new ProcessedData(raw.getValue() * 2);
       } catch (InterruptedException e) {
       Thread.currentThread().interrupt();
       throw new RuntimeException(e);
       }
       }
       
       public void shutdown() {
       customThreadPool.shutdown();
       try {
       if (!customThreadPool.awaitTermination(60, TimeUnit.SECONDS)) {
       customThreadPool.shutdownNow();
       }
       } catch (InterruptedException e) {
       customThreadPool.shutdownNow();
       Thread.currentThread().interrupt();
       }
       }
      }
      ```

      #### **3. Collection Optimization Patterns**
      ```java
      import it.unimi.dsi.fastutil.ints.*;
      import com.google.common.collect.*;

      public class CollectionOptimizer {
       
       // ❌ AVOID: Generic collections for primitive types
       public int sumIntegersSlow(List<Integer> numbers) {
       return numbers.stream().mapToInt(Integer::intValue).sum();
       // Boxing/unboxing overhead
       }
       
       // ✅ IMPLEMENT: Primitive collections
       public int sumIntegersOptimized(IntList numbers) {
       int sum = 0;
       IntIterator iterator = numbers.iterator();
       while (iterator.hasNext()) {
       sum += iterator.nextInt(); // No boxing
       }
       return sum;
       }
       
       // Memory-efficient data structures
       public static class OptimizedDataStore {
       // Use memory-efficient collections
       private final Int2ObjectOpenHashMap<String> idToName = new Int2ObjectOpenHashMap<>();
       private final Object2IntOpenHashMap<String> nameToId = new Object2IntOpenHashMap<>();
       private final IntList activeIds = new IntArrayList();
       
       // Use builder pattern for immutable collections
       private final ImmutableList<String> staticData;
       private final ImmutableMap<String, String> configMap;
       
       public OptimizedDataStore(List<String> staticDataList, Map<String, String> config) {
       this.staticData = ImmutableList.copyOf(staticDataList);
       this.configMap = ImmutableMap.copyOf(config);
       
       // Set default return value to avoid null checks
       nameToId.defaultReturnValue(-1);
       }
       
       public void addMapping(int id, String name) {
       idToName.put(id, name);
       nameToId.put(name, id);
       activeIds.add(id);
       }
       
       public Optional<String> getName(int id) {
       return Optional.ofNullable(idToName.get(id));
       }
       
       public int getId(String name) {
       int id = nameToId.getInt(name);
       return id == -1? -1: id; // Use default value pattern
       }
       
       // Efficient bulk operations
       public IntList getActiveIds() {
       return new IntArrayList(activeIds); // Defensive copy
       }
       }
       
       // Custom collection for specific use cases
       public static class CircularBuffer<T> {
       private final Object[] buffer;
       private final int capacity;
       private int head = 0;
       private int tail = 0;
       private int size = 0;
       
       @SuppressWarnings("unchecked")
       public CircularBuffer(int capacity) {
       this.capacity = capacity;
       this.buffer = new Object[capacity];
       }
       
       public synchronized boolean offer(T item) {
       if (size == capacity) {
       // Overwrite oldest item
       head = (head + 1) % capacity;
       } else {
       size++;
       }
       
       buffer[tail] = item;
       tail = (tail + 1) % capacity;
       return true;
       }
       
       @SuppressWarnings("unchecked")
       public synchronized T poll() {
       if (size == 0) {
       return null;
       }
       
       T item = (T) buffer[head];
       buffer[head] = null; // Help GC
       head = (head + 1) % capacity;
       size--;
       return item;
       }
       
       public synchronized int size() {
       return size;
       }
       }
      }
      ```

      ### **Spring Boot Optimization Patterns**

      #### **1. High-Performance REST Controller**
      ```java
      import org.springframework.web.bind.annotation.*;
      import org.springframework.http.ResponseEntity;
      import org.springframework.cache.annotation.Cacheable;
      import org.springframework.web.servlet.mvc.method.annotation.StreamingResponseBody;
      import reactor.core.publisher.Flux;
      import reactor.core.publisher.Mono;

      @RestController
      @RequestMapping("/api/v1")
      @Validated
      public class OptimizedController {
       
       private final DataService dataService;
       private final AsyncService asyncService;
       private final CacheManager cacheManager;
       
       public OptimizedController(DataService dataService, 
       AsyncService asyncService,
       CacheManager cacheManager) {
       this.dataService = dataService;
       this.asyncService = asyncService;
       this.cacheManager = cacheManager;
       }
       
       // ❌ AVOID: Blocking operations in request thread
       @GetMapping("/data-slow/{id}")
       public ResponseEntity<DataDTO> getDataSlow(@PathVariable Long id) {
       DataDTO data = dataService.findById(id); // Blocks request thread
       return ResponseEntity.ok(data);
       }
       
       // ✅ IMPLEMENT: Reactive programming with WebFlux
       @GetMapping("/data/{id}")
       public Mono<ResponseEntity<DataDTO>> getData(@PathVariable Long id) {
       return dataService.findByIdAsync(id).map(ResponseEntity::ok).defaultIfEmpty(ResponseEntity.notFound().build()).doOnError(error -> log.error("Error fetching data for id: {}", id, error));
       }
       
       // Streaming response for large datasets
       @GetMapping("/data/stream")
       public ResponseEntity<StreamingResponseBody> streamData(
       @RequestParam(defaultValue = "0") int page,
       @RequestParam(defaultValue = "1000") int size) {
       
       StreamingResponseBody stream = outputStream -> {
       try (JsonGenerator generator = objectMapper.createGenerator(outputStream)) {
       generator.writeStartArray();
       
       dataService.streamData(page, size).forEach(item -> {
       try {
       generator.writeObject(item);
       generator.flush();
       } catch (IOException e) {
       throw new UncheckedIOException(e);
       }
       });
       
       generator.writeEndArray();
       }
       };
       
       return ResponseEntity.ok().header(HttpHeaders.CONTENT_TYPE, MediaType.APPLICATION_JSON_VALUE).body(stream);
       }
       
       // Bulk operations with validation
       @PostMapping("/data/bulk")
       public Mono<ResponseEntity<BulkOperationResult>> createBulkData(
       @Valid @RequestBody List<CreateDataRequest> requests) {
       
       if (requests.size() > 1000) {
       return Mono.just(ResponseEntity.badRequest().body(new BulkOperationResult(0, 0, "Batch size too large")));
       }
       
       return asyncService.processBulkData(requests).map(result -> ResponseEntity.ok(result)).onErrorReturn(ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new BulkOperationResult(0, 0, "Processing failed")));
       }
       
       // Optimized caching with conditional updates
       @GetMapping("/data/cached/{id}")
       @Cacheable(value = "dataCache", key = "#id", 
       condition = "#id > 0", unless = "#result == null")
       public Mono<DataDTO> getCachedData(@PathVariable Long id) {
       return dataService.findByIdAsync(id);
       }
       
       // Cache eviction endpoint
       @DeleteMapping("/cache/{id}")
       public Mono<ResponseEntity<Void>> evictCache(@PathVariable Long id) {
       return Mono.fromCallable(() -> {
       cacheManager.getCache("dataCache").evict(id);
       return ResponseEntity.ok().<Void>build();
       });
       }
      }

      // Optimized service layer
      @Service
      @Transactional(readOnly = true)
      public class OptimizedDataService {
       
       private final DataRepository repository;
       private final RedisTemplate<String, Object> redisTemplate;
       private final ApplicationEventPublisher eventPublisher;
       
       // Async method with custom thread pool
       @Async("dataProcessingExecutor")
       public CompletableFuture<List<DataDTO>> processDataAsync(List<Long> ids) {
       List<DataDTO> results = new ArrayList<>(ids.size());
       
       // Process in batches to avoid overwhelming the database
       Lists.partition(ids, 100).forEach(batch -> {
       List<Data> entities = repository.findAllByIdIn(batch);
       entities.stream().map(this::convertToDTO).forEach(results::add);
       });
       
       return CompletableFuture.completedFuture(results);
       }
       
       // Reactive data access
       public Flux<DataDTO> streamDataReactive(int page, int size) {
       return Flux.fromStream(() -> 
       repository.findAll(PageRequest.of(page, size)).stream().map(this::convertToDTO)
       ).subscribeOn(Schedulers.boundedElastic());
       }
       
       // Optimized transaction management
       @Transactional(propagation = Propagation.REQUIRES_NEW, 
       isolation = Isolation.READ_COMMITTED,
       timeout = 30)
       public DataDTO createData(CreateDataRequest request) {
       Data entity = new Data();
       entity.setName(request.getName());
       entity.setValue(request.getValue());
       entity.setCreatedAt(Instant.now());
       
       Data saved = repository.save(entity);
       
       // Async event publishing
       eventPublisher.publishEvent(new DataCreatedEvent(saved.getId()));
       
       return convertToDTO(saved);
       }
      }
      ```

      #### **2. JPA/Hibernate Optimization**
      ```java
      import org.hibernate.annotations.*;
      import javax.persistence.*;
      import javax.persistence.Entity;

      // ✅ Optimized entity design
      @Entity
      @Table(name = "optimized_data", 
       indexes = {
       @Index(name = "idx_name", columnList = "name"),
       @Index(name = "idx_created_at", columnList = "created_at"),
       @Index(name = "idx_composite", columnList = "status, created_at")
       })
      @NamedQueries({
       @NamedQuery(
       name = "Data.findByStatusOptimized",
       query = "SELECT d FROM Data d WHERE d.status =:status ORDER BY d.createdAt DESC"
       ),
       @NamedQuery(
       name = "Data.countByStatus",
       query = "SELECT COUNT(d) FROM Data d WHERE d.status =:status"
       )
      })
      @NamedEntityGraph(
       name = "Data.withDetails",
       attributeNodes = {
       @NamedAttributeNode("details"),
       @NamedAttributeNode(value = "category", subgraph = "category-subgraph")
       },
       subgraphs = {
       @NamedSubgraph(
       name = "category-subgraph",
       attributeNodes = @NamedAttributeNode("parent")
       )
       }
      )
      @BatchSize(size = 20) // Optimize N+1 queries
      @DynamicUpdate // Only update changed fields
      @DynamicInsert // Only insert non-null fields
      @Cacheable
      @org.hibernate.annotations.Cache(usage = CacheConcurrencyStrategy.READ_WRITE)
      public class Data {
       
       @Id
       @GeneratedValue(strategy = GenerationType.SEQUENCE, generator = "data_seq")
       @SequenceGenerator(name = "data_seq", sequenceName = "data_sequence", 
       allocationSize = 50) // Batch sequence allocation
       private Long id;
       
       @Column(name = "name", nullable = false, length = 255)
       private String name;
       
       @Column(name = "value", nullable = false)
       private BigDecimal value;
       
       @Enumerated(EnumType.STRING)
       @Column(name = "status", nullable = false)
       private DataStatus status;
       
       @Column(name = "created_at", nullable = false, updatable = false)
       private Instant createdAt;
       
       @Column(name = "updated_at")
       private Instant updatedAt;
       
       @Version
       private Long version; // Optimistic locking
       
       // Lazy loading with fetch strategy
       @OneToMany(mappedBy = "data", cascade = CascadeType.ALL, 
       orphanRemoval = true, fetch = FetchType.LAZY)
       @BatchSize(size = 10)
       @OrderBy("createdAt DESC")
       private List<DataDetail> details = new ArrayList<>();
       
       @ManyToOne(fetch = FetchType.LAZY)
       @JoinColumn(name = "category_id")
       private Category category;
       
       // Lifecycle callbacks
       @PrePersist
       protected void onCreate() {
       createdAt = Instant.now();
       updatedAt = createdAt;
       }
       
       @PreUpdate
       protected void onUpdate() {
       updatedAt = Instant.now();
       }
       
       // Helper methods for collections
       public void addDetail(DataDetail detail) {
       details.add(detail);
       detail.setData(this);
       }
       
       public void removeDetail(DataDetail detail) {
       details.remove(detail);
       detail.setData(null);
       }
      }

      // Optimized repository
      @Repository
      public interface OptimizedDataRepository extends JpaRepository<Data, Long>, 
       JpaSpecificationExecutor<Data> {
       
       // Query optimization with pagination
       @Query("SELECT d FROM Data d WHERE d.status =:status ORDER BY d.createdAt DESC")
       Page<Data> findByStatusOptimized(@Param("status") DataStatus status, Pageable pageable);
       
       // Projection for read-only operations
       @Query("SELECT new com.example.dto.DataSummaryDTO(d.id, d.name, d.value, d.status) " +
       "FROM Data d WHERE d.createdAt >=:since")
       List<DataSummaryDTO> findSummariesSince(@Param("since") Instant since);
       
       // Native query for complex operations
       @Query(value = "SELECT * FROM optimized_data d " +
       "WHERE d.status =?1 AND d.created_at >=?2 " +
       "ORDER BY d.value DESC " +
       "LIMIT?3", nativeQuery = true)
       List<Data> findTopByStatusAndDateNative(String status, Instant since, int limit);
       
       // Bulk operations
       @Modifying
       @Query("UPDATE Data d SET d.status =:newStatus WHERE d.id IN:ids")
       int bulkUpdateStatus(@Param("newStatus") DataStatus newStatus, @Param("ids") List<Long> ids);
       
       // Stream for large datasets
       @QueryHints(@QueryHint(name = "org.hibernate.fetchSize", value = "100"))
       Stream<Data> streamByStatus(DataStatus status);
       
       // Entity graph usage
       @EntityGraph("Data.withDetails")
       Optional<Data> findWithDetailsById(Long id);
      }

      // Custom repository implementation for complex queries
      @Component
      public class DataRepositoryCustomImpl implements DataRepositoryCustom {
       
       @PersistenceContext
       private EntityManager entityManager;
       
       @Override
       public List<Data> findWithDynamicFilters(DataSearchCriteria criteria) {
       CriteriaBuilder cb = entityManager.getCriteriaBuilder();
       CriteriaQuery<Data> query = cb.createQuery(Data.class);
       Root<Data> root = query.from(Data.class);
       
       List<Predicate> predicates = new ArrayList<>();
       
       if (criteria.getName()!= null) {
       predicates.add(cb.like(cb.lower(root.get("name")), 
       "%" + criteria.getName().toLowerCase() + "%"));
       }
       
       if (criteria.getMinValue()!= null) {
       predicates.add(cb.greaterThanOrEqualTo(root.get("value"), criteria.getMinValue()));
       }
       
       if (criteria.getStatus()!= null) {
       predicates.add(cb.equal(root.get("status"), criteria.getStatus()));
       }
       
       query.where(predicates.toArray(new Predicate[0]));
       query.orderBy(cb.desc(root.get("createdAt")));
       
       TypedQuery<Data> typedQuery = entityManager.createQuery(query);
       
       // Apply pagination if specified
       if (criteria.getOffset()!= null) {
       typedQuery.setFirstResult(criteria.getOffset());
       }
       if (criteria.getLimit()!= null) {
       typedQuery.setMaxResults(criteria.getLimit());
       }
       
       return typedQuery.getResultList();
       }
      }
      ```

      ### **Reactive Programming with WebFlux**

      #### **1. Reactive Service Implementation**
      ```java
      import reactor.core.publisher.*;
      import reactor.core.scheduler.Schedulers;
      import org.springframework.web.reactive.function.client.WebClient;

      @Service
      public class ReactiveDataService {
       
       private final WebClient webClient;
       private final R2dbcEntityTemplate r2dbcTemplate;
       private final RedisReactiveTemplate<String, Object> redisTemplate;
       
       public ReactiveDataService(WebClient.Builder webClientBuilder,
       R2dbcEntityTemplate r2dbcTemplate,
       RedisReactiveTemplate<String, Object> redisTemplate) {
       this.webClient = webClientBuilder.baseUrl("https://api.external-service.com").defaultHeader(HttpHeaders.CONTENT_TYPE, MediaType.APPLICATION_JSON_VALUE).build();
       this.r2dbcTemplate = r2dbcTemplate;
       this.redisTemplate = redisTemplate;
       }
       
       // Reactive data processing with error handling
       public Flux<ProcessedData> processDataReactive(Flux<RawData> dataStream) {
       return dataStream.buffer(100) // Process in batches of 100.flatMap(batch -> 
       Flux.fromIterable(batch).parallel(4) // Use 4 parallel rails.runOn(Schedulers.parallel()).map(this::processItem).doOnError(error -> log.error("Error processing item", error)).onErrorResume(error -> Mono.just(createErrorResult(error))).sequential()
       ).doOnNext(result -> log.debug("Processed: {}", result)).publishOn(Schedulers.boundedElastic()); // Switch to I/O scheduler for downstream
       }
       
       // Reactive database operations with caching
       public Mono<DataEntity> findByIdWithCache(Long id) {
       String cacheKey = "data:" + id;
       
       return redisTemplate.opsForValue().get(cacheKey).cast(DataEntity.class).switchIfEmpty(
       r2dbcTemplate.selectOne(
       Query.query(Criteria.where("id").is(id)),
       DataEntity.class
       ).flatMap(entity -> 
       redisTemplate.opsForValue().set(cacheKey, entity, Duration.ofMinutes(30)).thenReturn(entity)
       )
       ).doOnError(error -> log.error("Error fetching data for id: {}", id, error));
       }
       
       // Reactive API composition
       public Mono<AggregatedData> aggregateFromMultipleSources(String identifier) {
       Mono<UserData> userData = fetchUserData(identifier).timeout(Duration.ofSeconds(5)).onErrorResume(error -> {
       log.warn("User data fetch failed for {}: {}", identifier, error.getMessage());
       return Mono.just(UserData.empty());
       });
       
       Mono<TransactionData> transactionData = fetchTransactionData(identifier).timeout(Duration.ofSeconds(3)).onErrorResume(error -> {
       log.warn("Transaction data fetch failed for {}: {}", identifier, error.getMessage());
       return Mono.just(TransactionData.empty());
       });
       
       Mono<PreferenceData> preferenceData = fetchPreferenceData(identifier).timeout(Duration.ofSeconds(2)).onErrorResume(error -> {
       log.warn("Preference data fetch failed for {}: {}", identifier, error.getMessage());
       return Mono.just(PreferenceData.empty());
       });
       
       return Mono.zip(userData, transactionData, preferenceData).map(tuple -> new AggregatedData(
       tuple.getT1(), // userData
       tuple.getT2(), // transactionData
       tuple.getT3() // preferenceData
       )).subscribeOn(Schedulers.boundedElastic());
       }
       
       private Mono<UserData> fetchUserData(String identifier) {
       return webClient.get().uri("/users/{id}", identifier).retrieve().onStatus(HttpStatus::is4xxClientError, 
       response -> Mono.error(new UserNotFoundException(identifier))).onStatus(HttpStatus::is5xxServerError,
       response -> Mono.error(new ExternalServiceException("User service unavailable"))).bodyToMono(UserData.class).retryWhen(Retry.backoff(3, Duration.ofSeconds(1)).maxBackoff(Duration.ofSeconds(10)));
       }
       
       // Reactive stream with backpressure handling
       public Flux<String> processLargeDataset(String datasetId) {
       return Flux.create(sink -> {
       try {
       // Simulate large dataset processing
       DatasetProcessor processor = new DatasetProcessor(datasetId);
       
       processor.process(item -> {
       if (sink.isCancelled()) {
       processor.stop();
       return;
       }
       
       sink.next(item);
       
       // Handle backpressure
       long requested = sink.requestedFromDownstream();
       if (requested == 0) {
       processor.pause();
       }
       });
       
       sink.complete();
       } catch (Exception e) {
       sink.error(e);
       }
       }, FluxSink.OverflowStrategy.BUFFER).onBackpressureBuffer(10000, BufferOverflowStrategy.DROP_OLDEST);
       }
      }
      ```

      ### **Testing Strategies**

      #### **1. Comprehensive Testing Framework**
      ```java
      @SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
      @TestPropertySource(properties = {
       "spring.datasource.url=jdbc:h2:mem:testdb",
       "spring.jpa.hibernate.ddl-auto=create-drop"
      })
      @DirtiesContext(classMode = DirtiesContext.ClassMode.AFTER_EACH_TEST_METHOD)
      class DataServiceIntegrationTest {
       
       @Autowired
       private TestRestTemplate restTemplate;
       
       @Autowired
       private DataRepository repository;
       
       @MockBean
       private ExternalApiClient externalApiClient;
       
       @Container
       static PostgreSQLContainer<?> postgres = new PostgreSQLContainer<>("postgres:13").withDatabaseName("testdb").withUsername("test").withPassword("test");
       
       @DynamicPropertySource
       static void configureProperties(DynamicPropertyRegistry registry) {
       registry.add("spring.datasource.url", postgres::getJdbcUrl);
       registry.add("spring.datasource.username", postgres::getUsername);
       registry.add("spring.datasource.password", postgres::getPassword);
       }
       
       @Test
       @Transactional
       @Rollback
       void testCreateData() {
       // Given
       CreateDataRequest request = new CreateDataRequest("Test", BigDecimal.valueOf(100));
       when(externalApiClient.validateData(any())).thenReturn(CompletableFuture.completedFuture(true));
       
       // When
       ResponseEntity<DataDTO> response = restTemplate.postForEntity(
       "/api/v1/data", 
       request, 
       DataDTO.class
       );
       
       // Then
       assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CREATED);
       assertThat(response.getBody()).isNotNull();
       assertThat(response.getBody().getName()).isEqualTo("Test");
       
       // Verify database state
       Optional<Data> savedData = repository.findById(response.getBody().getId());
       assertThat(savedData).isPresent();
       assertThat(savedData.get().getName()).isEqualTo("Test");
       }
       
       @Test
       @Sql("/test-data.sql")
       void testFindDataWithPagination() {
       // When
       ResponseEntity<PagedModel<DataDTO>> response = restTemplate.exchange(
       "/api/v1/data?page=0&size=10&sort=createdAt,desc",
       HttpMethod.GET,
       null,
       new ParameterizedTypeReference<PagedModel<DataDTO>>() {}
       );
       
       // Then
       assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
       assertThat(response.getBody()).isNotNull();
       assertThat(response.getBody().getContent()).hasSize(10);
       }
       
       @Test
       void testBulkDataCreation() {
       // Given
       List<CreateDataRequest> requests = IntStream.range(1, 101).mapToObj(i -> new CreateDataRequest("Item " + i, BigDecimal.valueOf(i))).collect(Collectors.toList());
       
       when(externalApiClient.validateData(any())).thenReturn(CompletableFuture.completedFuture(true));
       
       // When
       StopWatch stopWatch = new StopWatch();
       stopWatch.start();
       
       ResponseEntity<BulkOperationResult> response = restTemplate.postForEntity(
       "/api/v1/data/bulk",
       requests,
       BulkOperationResult.class
       );
       
       stopWatch.stop();
       
       // Then
       assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
       assertThat(response.getBody().getSuccessCount()).isEqualTo(100);
       assertThat(stopWatch.getTotalTimeMillis()).isLessThan(5000); // Performance assertion
       
       // Verify all records were created
       long count = repository.count();
       assertThat(count).isEqualTo(100);
       }
      }

      // Performance testing
      @TestMethodOrder(OrderAnnotation.class)
      class PerformanceTest {
       
       private DataService dataService;
       private List<CreateDataRequest> testData;
       
       @BeforeEach
       void setUp() {
       testData = generateTestData(10000);
       }
       
       @Test
       @Order(1)
       @Timeout(value = 30, unit = TimeUnit.SECONDS)
       void testBulkProcessingPerformance() {
       // Given
       StopWatch stopWatch = new StopWatch();
       
       // When
       stopWatch.start();
       List<DataDTO> results = dataService.processBulkData(testData);
       stopWatch.stop();
       
       // Then
       assertThat(results).hasSize(10000);
       assertThat(stopWatch.getTotalTimeMillis()).isLessThan(30000);
       
       double throughput = (double) results.size() / (stopWatch.getTotalTimeMillis() / 1000.0);
       System.out.println(String.format("Throughput: %.2f items/second", throughput));
       assertThat(throughput).isGreaterThan(100); // Minimum acceptable throughput
       }
       
       @Test
       @RepeatedTest(5)
       void testMemoryUsageStability() {
       // Given
       MemoryMXBean memoryBean = ManagementFactory.getMemoryMXBean();
       long initialMemory = memoryBean.getHeapMemoryUsage().getUsed();
       
       // When
       List<DataDTO> results = dataService.processBulkData(testData);
       
       // Force garbage collection
       System.gc();
       Thread.sleep(1000);
       
       long finalMemory = memoryBean.getHeapMemoryUsage().getUsed();
       
       // Then
       long memoryIncrease = finalMemory - initialMemory;
       assertThat(memoryIncrease).isLessThan(100 * 1024 * 1024); // Less than 100MB increase
       System.out.println(String.format("Memory increase: %d MB", memoryIncrease / (1024 * 1024)));
       }
      }
      ```

      ## 🛠️ PRODUCTION OPTIMIZATION

      ### **JVM Tuning Configuration**
      ```bash
      # JVM startup parameters for production
      JAVA_OPTS="
      -server
      -Xms4g -Xmx4g # Heap size (adjust based on available memory)
      -XX:+UseG1GC # Use G1 garbage collector
      -XX:MaxGCPauseMillis=100 # Target GC pause time
      -XX:+UseStringDeduplication # Reduce memory usage for duplicate strings
      -XX:+OptimizeStringConcat # Optimize string concatenation
      -XX:+UseCompressedOops # Use compressed object pointers (< 32GB heap)
      -XX:+UseCompressedClassPointers # Compress class metadata
      -XX:NewRatio=2 # Young generation size
      -XX:+UnlockExperimentalVMOptions
      -XX:+UseJVMCICompiler # Use JVMCI compiler if available
      -XX:+PrintGC # Print GC information
      -XX:+PrintGCDetails
      -XX:+PrintGCTimeStamps
      -XX:+UseGCLogFileRotation
      -XX:NumberOfGCLogFiles=10
      -XX:GCLogFileSize=10M
      -Xloggc:/var/log/app/gc.log
      -XX:+HeapDumpOnOutOfMemoryError # Create heap dump on OOM
      -XX:HeapDumpPath=/var/log/app/
      -XX:+ExitOnOutOfMemoryError # Exit JVM on OOM
      -Djava.awt.headless=true # Headless mode
      -Dfile.encoding=UTF-8 # Default encoding
      -Duser.timezone=UTC # UTC timezone
      -Dspring.profiles.active=production
      "
